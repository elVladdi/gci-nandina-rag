# Entornos y dependencias
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Configuración local y secretos
.env
.env.*
*.key
*.pem
secrets/
credentials/

# Datos sensibles o pesados
/data/raw/*
/data/interim/*
/data/processed/*
/data/external/*
!/data/raw/.gitkeep
!/data/interim/.gitkeep
!/data/processed/.gitkeep
!/data/external/.gitkeep

# Resultados generados
/outputs/*
!/outputs/.gitkeep

# Modelos e índices locales
/models/*
!/models/.gitkeep
/indexes/*
!/indexes/.gitkeep

# Archivos de sistema
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Documentos temporales
~$*.docx
*.tmp
*.bak
